[Nemo Action]
# Mandatory fields
Name=Tabs to spaces
Exec=perl -e '$result = `expand -t4 %F`; print $result =~ s/^( +)/"\\033[44m \\033[0m" x length($1)/gmer; print "\nOK?[y/N]"; $reply = <>; if ($reply =~ m/y.*/i) { open my $fh, ">", %F or die; print $fh $result; close $fh }'
Selection=s

Mimetypes=text/*;application/*;
# Optional fields
Comment=Change indentation via expand
Icon-Name=format-indent-more-symbolic
Quote=double
Dependencies=perl;unexpand;
Terminal=true
