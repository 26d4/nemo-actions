[Nemo Action]
# Mandatory fields
Name=Spaces to tabs
Exec=bash -c 'RESULT="$(unexpand -t4 %F)"; echo -e "$(echo "$RESULT" | sed "s/\\t/\\\\\\033[44m   >\\\\\\033[0m/g")"; read -N1 -pOK?[y/N]; case "$REPLY" in "y"*|"Y"*) echo "$RESULT" > %F;; esac'
Selection=s

Mimetypes=text/*;application/*;
# Optional fields
Comment=Change indentation via unexpand
Icon-Name=format-indent-more-symbolic
Quote=single
Dependencies=bash;sed;unexpand;
Terminal=true
